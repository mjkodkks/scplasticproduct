---
import { languages, defaultLang } from "@i18n/ui";
import { getLangFromUrl } from "@i18n/utils";

// props isMobile
const { isMobile } = Astro.props;

const currentLang = getLangFromUrl(Astro.url);
const currentLabel = languages[currentLang];

// Rebuild the current path in the target language
function switchLangPath(targetLang: string) {
  const pathname = Astro.url.pathname;
  // Strip leading slash and split
  const parts = pathname.replace(/^\//, "").split("/");
  // If the first segment is a known locale, replace it; otherwise prepend
  const isLocalePrefix = parts[0] in languages;
  if (targetLang === defaultLang) {
    // default lang has no prefix
    const rest = isLocalePrefix ? parts.slice(1) : parts;
    return "/" + rest.join("/") || "/";
  }
  const rest = isLocalePrefix ? parts.slice(1) : parts;
  return `/${targetLang}/${rest.join("/")}`;
}
---

{
  isMobile ? (
    <div>
      {Object.entries(languages).map(([lang, label], i) => (
        <div
          role="menuitem">
          <a
            href={switchLangPath(lang)}
            class:list={[
              "block px-3 py-2 text-sm text-black",
              { "font-semibold": lang === currentLang },
            ]}>
            {label}
          </a>
        </div>
      ))}
    </div>
  ) : (
    <div class="relative group/lang">
      <button
        class="flex items-center gap-1 text-white cursor-pointer"
        aria-haspopup="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="1.2em"
          height="1.2em"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round">
          <circle cx="12" cy="12" r="10" />
          <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
        </svg>
        <span class="text-sm">{currentLabel}</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="1em"
          height="1em"
          class="group-hover/lang:rotate-90 transition-all duration-300"
          viewBox="0 0 24 24">
          <path
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="m10 17 5-5-5-5"
          />
        </svg>
      </button>

      <ul
        class="absolute right-0 top-full min-w-[120px] bg-white rounded-md shadow-md opacity-0 invisible group-hover/lang:opacity-100 group-hover/lang:visible transition-all duration-300 flex flex-col"
        role="menu">
        {Object.entries(languages).map(([lang, label], i) => (
          <li
            role="menuitem"
            class="hover:bg-primary-100 rounded-md opacity-0 translate-y-2 group-hover/lang:opacity-100 group-hover/lang:translate-y-0 transition-all duration-300"
            style={`transition-delay: ${i * 60}ms`}>
            <a
              href={switchLangPath(lang)}
              class:list={[
                "block px-3 py-2 text-sm text-black",
                { "font-semibold": lang === currentLang },
              ]}>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )
}
