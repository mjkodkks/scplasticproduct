---
import Container from "@components/container.astro";
import Hero from "@components/home/hero.astro";
import Layout from "@layouts/Layout.astro";
import Carousel from "@components/home/carousel.astro";
import Product from "@components/home/product.astro";
import Project from "@components/home/project.astro";
import Ourservice from "@components/home/ourservice.astro";
import { languages } from "@i18n/ui";

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
---

<Layout title="หน้าหลัก">
  <Carousel />
  <Hero />
  <Ourservice />
  <Product />
  <Project />
</Layout>
